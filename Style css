body{
margin:0;
font-family:Arial;
background:#f5f5f5;
}

header{
background:#0d47a1;
color:white;
text-align:center;
padding:30px;
}

.card{
background:white;
width:90%;
margin:20px auto;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px lightgray;
}

h2{
color:#0d47a1;
}

button{
display:block;
margin:30px auto;
padding:12px 25px;
font-size:18px;
background:#0d47a1;
color:white;
border:none;
border-radius:8px;
cursor:pointer;
}

button:hover{
background:#1565c0;
}
